{
  "name": "sistema-matricula",
  "version": "1.0.0",
  "description": "Sistema de matrícula escolar",
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.sistema.matricula",
    "productName": "Sistema Matricula",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/*",
      "!*.log",
      "!README.md"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sistema Matricula"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "bcryptjs": "^3.0.3",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "png-to-ico": "^3.0.1",
    "sqlite3": "^5.1.7",
    "xlsx": "^0.18.5"
  }
}
